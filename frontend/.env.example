# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth (iron-session)
SESSION_SECRET=generate-a-random-32-byte-hex-string

# Chain (set to "mainnet" for Base mainnet, "testnet" for Base Sepolia)
NEXT_PUBLIC_BASE_CHAIN_ID=8453
NEXT_PUBLIC_CHAIN=mainnet
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Escrow Contract (deploy via Foundry, paste address here)
NEXT_PUBLIC_ESCROW_ADDRESS=0x

# ZK Proof Verifier Contract
NEXT_PUBLIC_VERIFIER_ADDRESS=0x
PROOF_SUBMITTER_PRIVATE_KEY=0x

# AI execution
ANTHROPIC_API_KEY=your-anthropic-api-key

# Site URL (required outside Vercel previews; preview branches derive this from Vercel system envs)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Reown AppKit (required for WalletConnect and broader wallet compatibility)
NEXT_PUBLIC_REOWN_PROJECT_ID=

# Cron secret (for Vercel cron auth)
CRON_SECRET=generate-a-random-secret

# Rate limiting (required in production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional operations
ALERT_WEBHOOK_URL=
SIGNER_MIN_BALANCE_ETH=0.01
AGENT_EXECUTION_TIMEOUT_MS=30000
AI_SPEND_CEILING_CENTS=10000
SAFE_POLICY_SIGNER_PRIVATE_KEY=0x
AGENT_SESSION_ENCRYPTION_KEY=base64-32-byte-key
SAFE7579_POLICY_MANAGER_ADDRESS=0x
SAFE7579_GUARD_ADDRESS=0x
SAFE7579_HOOK_ADDRESS=0x
SAFE7579_ADAPTER_ADDRESS=0x7579f2ad53b01c3d8779fe17928e0d48885b0003
SAFE7579_OWNER_VALIDATOR_ADDRESS=0x000000000013fdb5234e4e3162a810f54d9f7e98
SAFE7579_SMART_SESSIONS_ADDRESS=0x00000000008bDABA73cD9815d79069c247Eb4bDA
SAFE7579_COMPATIBILITY_FALLBACK_ADDRESS=0x000000000052e9685932845660777DF43C2dC496
SAFE7579_BUNDLER_URL=
SAFE7579_PAYMASTER_URL=

# GA observability
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
