# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth (iron-session)
SESSION_SECRET=generate-a-random-32-byte-hex-string

# Chain (set to "mainnet" for Base mainnet, "testnet" for Base Sepolia)
NEXT_PUBLIC_BASE_CHAIN_ID=8453
NEXT_PUBLIC_CHAIN=mainnet
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Escrow Contract (deploy via Foundry, paste address here)
NEXT_PUBLIC_ESCROW_ADDRESS=0x

# Site URL (required for CSRF protection in production)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Cron secret (for Vercel cron auth)
CRON_SECRET=generate-a-random-secret
